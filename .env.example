# Vercel Postgres (Neon) — `vercel env pull .env.local`로 자동 주입됨
DATABASE_URL=

# Cafe24 App (개발자센터에서 발급)
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
CAFE24_REDIRECT_URI=http://localhost:3000/api/cafe24/oauth/callback
# 테스트몰 ID (xxxx.cafe24.com 의 xxxx)
CAFE24_TEST_MALL_ID=

# 관리자 세션 시크릿
AUTH_SECRET=change-me
