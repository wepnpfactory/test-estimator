// 가변 옵션 상품 관리 사이트 스키마
// 고도몰 → Cafe24 이관을 위한 "동적 상품 생성형" 가변 옵션 모델

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Cafe24 몰 연동 정보
// ─────────────────────────────────────────────
model Cafe24Mall {
  id             String    @id @default(cuid())
  mallId         String    @unique // Cafe24 mall_id
  name           String
  clientId       String
  clientSecret   String
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  scopes         String[]  @default([])
  defaultCategoryNo   Int?
  hideDynamicProducts Boolean @default(true)
  // 동적 일회용 상품 등록 시 사용할 카테고리 (없으면 무카테고리)
  dynamicCategoryNo   Int?
  // 쇼핑몰 → API 호출 시 허용할 Origin 화이트리스트 (정확 매칭)
  // 비어 있으면 storefrontOrigin + {mallId}.cafe24.com 자동 허용
  allowedOrigins      String[] @default([])
  // embed.js → quote/checkout HMAC 서명 키 (몰별로 다름)
  embedSecret         String?
  // 고객 브라우저가 장바구니로 이동할 때 사용할 storefront origin
  // 예: https://hitedin.cafe24.com 또는 커스텀 도메인
  // OAuth 콜백에서 자동 세팅, 미설정 시 mallId.cafe24.com 폴백
  storefrontOrigin    String?
  // 멀티샵의 경우 기본 shop_no
  defaultShopNo       Int     @default(1)

  products        Product[]
  dynamicProducts DynamicProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// 관리자가 등록하는 "원본 가변 옵션 상품"
// ─────────────────────────────────────────────
model Product {
  id           String     @id @default(cuid())
  mall         Cafe24Mall @relation(fields: [mallId], references: [id])
  mallId       String

  name            String
  slug            String  @unique
  description     String?
  thumbnailUrl    String?
  basePrice       Int     @default(0)
  cafe24ProductNo Int?

  status ProductStatus @default(DRAFT)

  @@unique([mallId, cafe24ProductNo])

  optionGroups    OptionGroup[]
  priceRules      PriceRule[]
  dynamicProducts DynamicProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mallId, status])
}

// Prisma 7: 복합 unique는 모델 본문 안에 위치해야 함 (위 정의 참고)

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────────
// 옵션 그룹 (예: 표지 재질, 페이지 수, 제본 방식)
// ─────────────────────────────────────────────
model OptionGroup {
  id        String @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  name        String
  displayType OptionDisplayType @default(SELECT)
  required    Boolean           @default(true)
  sortOrder   Int               @default(0)
  kind        OptionGroupKind   @default(NORMAL)
  // 이 그룹이 노출되는 조건. 형식: [{ groupId, itemId }, ...] — 모두 만족(AND)해야 노출.
  // null/빈 배열이면 항상 노출.
  showWhen    Json?

  items OptionItem[]

  @@index([productId, sortOrder])
}

enum OptionGroupKind {
  NORMAL
  SHEET_COUNT // 페이지수 그룹 — 선택된 item.multiplier 가 sheet 수
  QUANTITY    // 부수 그룹 — 선택된 item.multiplier 가 quantity
}

enum OptionDisplayType {
  SELECT
  RADIO
  SWATCH
  NUMBER
}

// ─────────────────────────────────────────────
// 옵션 선택지
// ─────────────────────────────────────────────
model OptionItem {
  id      String      @id @default(cuid())
  group   OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  label     String
  value     String
  addPrice  Int     @default(0)
  // 부모 그룹이 SHEET_COUNT/QUANTITY 일 때 의미 — 장수/부수 값
  multiplier  Int     @default(1)
  // addPrice 를 sheet 수에 곱함 (예: 종이값/인쇄비)
  perSheet    Boolean @default(false)
  // addPrice 를 부수에 곱함 (예: 코팅비, 타공비)
  perQuantity Boolean @default(false)
  stock     Int?
  imageUrl  String?
  sortOrder Int     @default(0)
  enabled   Boolean @default(true)

  @@unique([groupId, value])
  @@index([groupId, sortOrder])
}

// ─────────────────────────────────────────────
// 가격 규칙
// ─────────────────────────────────────────────
model PriceRule {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  name       String
  conditions Json
  action     PriceRuleAction
  amount     Int
  sortOrder  Int @default(0)

  @@index([productId, sortOrder])
}

enum PriceRuleAction {
  ADD_FIXED
  SUBTRACT_FIXED
  ADD_PERCENT
  SUBTRACT_PERCENT
  OVERRIDE
}

// ─────────────────────────────────────────────
// 구매 시 동적으로 Cafe24에 등록되는 일회용 상품
// ─────────────────────────────────────────────
model DynamicProduct {
  id              String     @id @default(cuid())
  mall            Cafe24Mall @relation(fields: [mallId], references: [id])
  mallId          String
  sourceProduct   Product    @relation(fields: [sourceProductId], references: [id])
  sourceProductId String

  cafe24ProductNo   Int?
  cafe24ProductCode String?

  selectedOptions Json
  finalPrice      Int

  // 고객 메타 (Cafe24 회원 / 게스트)
  customerId      String?
  customerEmail   String?
  customerName    String?

  // 디자인·첨부 파일 (jarvis 에디터·외부 S3 결과)
  designNo  String? // wepnpSeqno
  fileUrl   String?
  fileName  String?

  // 주문 동기화 결과
  cafe24OrderId    String?
  orderedAt        DateTime?
  rawOrderSnapshot Json?

  status    DynamicProductStatus @default(CREATED)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mallId, status])
  @@index([expiresAt])
  @@index([cafe24OrderId])
  @@index([customerId])
}

enum DynamicProductStatus {
  CREATED
  IN_CART
  ORDERED
  DEACTIVATED
  EXPIRED
  FAILED
}
