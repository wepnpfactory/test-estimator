// 가변 옵션 상품 관리 사이트 스키마
// 고도몰 → Cafe24 이관을 위한 "동적 상품 생성형" 가변 옵션 모델

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Cafe24 몰 연동 정보
// ─────────────────────────────────────────────
model Cafe24Mall {
  id             String    @id @default(cuid())
  mallId         String    @unique // Cafe24 mall_id
  name           String
  clientId       String
  clientSecret   String
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  scopes         String[]  @default([])
  defaultCategoryNo   Int?
  hideDynamicProducts Boolean @default(true)
  // 동적 일회용 상품 등록 시 사용할 카테고리 (없으면 무카테고리)
  dynamicCategoryNo   Int?
  // 쇼핑몰 → API 호출 시 허용할 Origin 화이트리스트 (정확 매칭)
  // 비어 있으면 storefrontOrigin + {mallId}.cafe24.com 자동 허용
  allowedOrigins      String[] @default([])
  // embed.js → quote/checkout HMAC 서명 키 (몰별로 다름)
  embedSecret         String?
  // 고객 브라우저가 장바구니로 이동할 때 사용할 storefront origin
  // 예: https://hitedin.cafe24.com 또는 커스텀 도메인
  // OAuth 콜백에서 자동 세팅, 미설정 시 mallId.cafe24.com 폴백
  storefrontOrigin    String?
  // 멀티샵의 경우 기본 shop_no
  defaultShopNo       Int     @default(1)

  products        Product[]
  dynamicProducts DynamicProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// 관리자가 등록하는 "원본 가변 옵션 상품"
// ─────────────────────────────────────────────
model Product {
  id           String     @id @default(cuid())
  mall         Cafe24Mall @relation(fields: [mallId], references: [id])
  mallId       String

  name            String
  slug            String  @unique
  description     String?
  thumbnailUrl    String?
  basePrice       Int     @default(0)
  cafe24ProductNo Int?
  // 면적 비례 가격 계산의 기준 면적 (mm²). A4 = 210 × 297 = 62370 (디폴트)
  baseAreaMm2     Int     @default(62370)
  // 인쇄 여백 (도련) — 편집/표지 사이즈 계산 시 양쪽으로 추가됨
  bleedMm         Int     @default(3)
  // 상품 템플릿 — 생성 시 어떤 옵션 그룹을 자동 스캐폴드할지
  template        ProductTemplate @default(NONE)

  status ProductStatus @default(DRAFT)

  @@unique([mallId, cafe24ProductNo])

  optionGroups    OptionGroup[]
  priceRules      PriceRule[]
  dynamicProducts DynamicProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mallId, status])
}

// Prisma 7: 복합 unique는 모델 본문 안에 위치해야 함 (위 정의 참고)

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductTemplate {
  NONE
  BOOKLET
  FLAT_PRINT
}

// ─────────────────────────────────────────────
// 옵션 그룹 (예: 표지 재질, 페이지 수, 제본 방식)
// ─────────────────────────────────────────────
model OptionGroup {
  id        String @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  name        String
  // 내부 식별용 슬러그 (영문/숫자/_-). 같은 product 안에서 unique.
  value       String?
  displayType OptionDisplayType @default(SELECT)
  required    Boolean           @default(true)
  sortOrder   Int               @default(0)
  kind        OptionGroupKind   @default(NORMAL)
  // 이 그룹이 노출되는 조건. 형식: [{ groupId, itemId }, ...] — 모두 만족(AND)해야 노출.
  // null/빈 배열이면 항상 노출.
  showWhen    Json?
  // DIMENSIONS 그룹에서 사용자가 입력 가능한 최대 가로/세로 (mm)
  maxWidthMm  Int?
  maxHeightMm Int?
  // 이 그룹의 모든 아이템 addPrice 를 sheet 수에 곱함 (예: 종이값/인쇄비)
  perSheet    Boolean @default(false)
  // 이 그룹의 모든 아이템 addPrice 를 부수에 곱함 (예: 코팅비, 타공비)
  perQuantity Boolean @default(false)
  // 이 그룹의 모든 아이템 addPrice 를 (선택된 사이즈 면적 / Product.baseAreaMm2) 에 곱함
  perArea     Boolean @default(false)
  // SHEET_COUNT / QUANTITY 그룹에서 사용자가 숫자를 직접 입력 (presets 대신)
  allowDirectInput Boolean @default(false)
  minDirectInput   Int?
  maxDirectInput   Int?
  // 책자류 구분: 이 그룹이 내지/표지 종이를 의미하면 표시
  // (책등 두께 / 표지 사이즈 자동 계산에 사용)
  // deprecated — kind 가 INNER_PAPER / COVER_PAPER 면 자동 true 로 간주 (마이그레이션 백필 완료 후 제거 예정)
  isInnerPaper     Boolean @default(false)
  isCoverPaper     Boolean @default(false)

  items OptionItem[]

  @@unique([productId, value])
  @@index([productId, sortOrder])
}

enum OptionGroupKind {
  NORMAL
  SHEET_COUNT // 페이지수 그룹 — 선택된 item.multiplier 가 sheet 수
  QUANTITY    // 부수 그룹 — 선택된 item.multiplier 가 quantity
  DIMENSIONS  // 사이즈 그룹 — 사용자가 가로/세로 mm 입력, 가장 작은 fit 옵션 자동 선택
  INNER_PAPER // 내지 종이 — NORMAL 과 동일 렌더, 책등/표지 사이즈 계산에 두께 사용
  COVER_PAPER // 표지 종이 — NORMAL 과 동일 렌더, 책등/표지 사이즈 계산에 두께 사용
}

enum OptionDisplayType {
  SELECT
  RADIO
  SWATCH
  NUMBER
}

// ─────────────────────────────────────────────
// 옵션 선택지
// ─────────────────────────────────────────────
model OptionItem {
  id      String      @id @default(cuid())
  group   OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  label     String
  value     String
  addPrice  Int     @default(0)
  // 부모 그룹이 SHEET_COUNT/QUANTITY 일 때 의미 — 장수/부수 값
  multiplier  Int     @default(1)
  // 부모 그룹이 DIMENSIONS 일 때 — 이 옵션이 커버하는 최대 사이즈 (mm)
  widthMm     Int?
  heightMm    Int?
  // SHEET_COUNT/QUANTITY 그룹이 allowDirectInput 일 때, 이 옵션이 매칭되는 구간
  // (예: 1~50, 51~100). minRange 이상 ~ maxRange 이하. null 이면 무한.
  minRange    Int?
  maxRange    Int?
  // 종이 옵션의 장당 두께 (mm) — 책등·표지 사이즈 계산에 사용
  thicknessMm Float?
  stock     Int?
  imageUrl  String?
  sortOrder Int     @default(0)
  enabled   Boolean @default(true)
  // 이 아이템이 노출되는 조건. 형식: [{ groupId, itemId }, ...] AND.
  // 그룹 showWhen 과 별개로 같은 그룹 안에서도 일부 아이템만 보이게 가능.
  showWhen  Json?

  @@unique([groupId, value])
  @@index([groupId, sortOrder])
}

// ─────────────────────────────────────────────
// 가격 규칙
// ─────────────────────────────────────────────
model PriceRule {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  name       String
  conditions Json
  action     PriceRuleAction
  amount     Int
  sortOrder  Int @default(0)

  @@index([productId, sortOrder])
}

enum PriceRuleAction {
  ADD_FIXED
  SUBTRACT_FIXED
  ADD_PERCENT
  SUBTRACT_PERCENT
  OVERRIDE
}

// ─────────────────────────────────────────────
// 구매 시 동적으로 Cafe24에 등록되는 일회용 상품
// ─────────────────────────────────────────────
model DynamicProduct {
  id              String     @id @default(cuid())
  mall            Cafe24Mall @relation(fields: [mallId], references: [id])
  mallId          String
  sourceProduct   Product    @relation(fields: [sourceProductId], references: [id])
  sourceProductId String

  cafe24ProductNo   Int?
  cafe24ProductCode String?

  selectedOptions Json
  finalPrice      Int

  // 고객 메타 (Cafe24 회원 / 게스트)
  customerId      String?
  customerEmail   String?
  customerName    String?

  // 디자인·첨부 파일 (jarvis 에디터·외부 S3 결과)
  designNo  String? // wepnpSeqno
  fileUrl   String?
  fileName  String?

  // 주문 동기화 결과
  cafe24OrderId    String?
  orderedAt        DateTime?
  rawOrderSnapshot Json?

  status    DynamicProductStatus @default(CREATED)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mallId, status])
  @@index([expiresAt])
  @@index([cafe24OrderId])
  @@index([customerId])
}

enum DynamicProductStatus {
  CREATED
  IN_CART
  ORDERED
  DEACTIVATED
  EXPIRED
  FAILED
}
